Time complexity: O(1)

class Solution:
    def deleteNode(self, node):
        """
        :type node: ListNode
        :rtype: void Do not return anything, modify node in-place instead.
        """
        node.val = node.next.val # Copy next value into current node, so 4 5 1 9 becomes 4 1 1 9
        node.next = node.next.next # Now we remove the duplicate 1


