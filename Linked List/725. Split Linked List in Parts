Time: O(n + k) Count the length → O(n); Split into k parts → O(n + k)
Space: O(k) for the result array

# Definition for singly-linked list.
# class ListNode:
#     def __init__(self, val=0, next=None):
#         self.val = val
#         self.next = next
class Solution:
    def splitListToParts(self, head: Optional[ListNode], k: int) -> List[Optional[ListNode]]:
        # find total length
        n = 0
        curr = head
        while curr:
            n += 1
            curr = curr.next
        

        base_size = n // k
        extra_size = n % k
        result = []
        curr = head

        for i in range(k):
            part_head = curr
            part_size = base_size + (1 if i < extra_size else 0)

            for j in range(part_size-1):
                if curr:
                    curr = curr.next
            
            # Cut the list
            if curr:
                next_part = curr.next
                curr.next = None
                curr = next_part

            result.append(part_head)

        return result
